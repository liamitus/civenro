# =============================================================================
# Civenro Environment Variables
# Copy this file to .env and fill in real values:  cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# Local dev: use docker compose up -d to start Postgres on port 5434
# Production: Supabase pooled connection string from your project dashboard
DATABASE_URL="postgresql://civenro:civenro@localhost:5434/civenro_dev"

# --- Supabase ----------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- AI Providers ------------------------------------------------------------
# At least one is required for the bill chat feature.
# Get keys from: https://platform.openai.com/api-keys
#                https://console.anthropic.com/settings/keys
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# --- External APIs -----------------------------------------------------------
# Google Civic (rep lookup by address): https://console.cloud.google.com/apis
GOOGLE_CIVIC_API_KEY="your-google-civic-key"

# Congress.gov (bill text, actions): https://api.congress.gov/sign-up/
CONGRESS_DOT_GOV_API_KEY="your-congress-api-key"

# --- Admin & Cron ------------------------------------------------------------
# ADMIN_API_KEY: required for /api/admin endpoints. Generate a strong secret.
ADMIN_API_KEY="generate-a-strong-random-secret"

# CRON_SECRET: Vercel sends this in the Authorization header for cron jobs.
# Set the same value in Vercel project settings.
CRON_SECRET="generate-a-strong-random-secret"

# --- Stripe (Donations) -----------------------------------------------------
# Use test keys for local dev: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
